---
export interface Props {
	date?: string;
}

const { date } = Astro.props;
---

{
	date ? (
		<div class="flex gap-4 pb-6 relative">
			{/* 时间线竖线 */}
			<div class="flex flex-col items-center shrink-0">
				<div class="w-3 h-3 rounded-full bg-(--primary) mt-1.5 shrink-0" />
				<div class="w-0.5 flex-1 bg-(--line-divider)" />
			</div>
			{/* 内容 */}
			<div class="flex-1 min-w-0 pt-0.5">
				<time class="text-xs text-(--primary) font-medium mb-1 block">{date}</time>
				<div class="text-sm text-black/75 dark:text-white/75 leading-relaxed">
					<slot />
				</div>
			</div>
		</div>
	) : (
		<div class="relative">
			<slot />
		</div>
	)
}
